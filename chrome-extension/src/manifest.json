{
  "manifest_version": 3,
  "name": "TEMPOC",
  "version": "1.3.2",
  "description": "Displays elapsed-time progress bars for Claude's 7-day and 5-hour usage windows on the Claude usage page.",
  "author": "secondarykey",
  "homepage_url": "https://secondarykey.github.io/TEMPOC/",
  "icons": {
    "16":  "tempoc.png",
    "32":  "tempoc.png",
    "48":  "tempoc.png",
    "128": "tempoc.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["bridge.js"]
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "world": "MAIN"
    }
  ]
}
