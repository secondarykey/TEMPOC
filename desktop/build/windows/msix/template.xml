<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="tempoc.exe"
        Arguments=""
        InstallLocation="C:\Program Files\secondarykey\TEMPOC">
    </Installer>
    <PackageInformation
        PackageName="TEMPOC"
        PackageDisplayName="TEMPOC"
        PublisherName="CN=secondarykey"
        PublisherDisplayName="secondarykey"
        Version="0.1.0.0"
        PackageDescription="TEMPOC - Claude usage window tracker">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.github.secondarykey.tempoc.desktop"
                Description="TEMPOC - Claude usage window tracker"
                DisplayName="TEMPOC"
                ExecutableName="tempoc.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>TEMPOC</DisplayName>
            <PublisherDisplayName>secondarykey</PublisherDisplayName>
            <Description>TEMPOC - Claude usage window tracker</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="tempoc.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
